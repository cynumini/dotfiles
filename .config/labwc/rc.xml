<labwc_config>

  <theme>
    <icon>buuf-nestort</icon>
    <fallbackAppIcon>hicolor</fallbackAppIcon>
    <cornerRadius>8</cornerRadius>
    <font name="Iosevka" size="12" />
  </theme>

  <libinput>
    <device category="default">
      <accelProfile>flat</accelProfile>
    </device>
  </libinput>

  <focus><followMouse>yes</followMouse></focus>

  <windowSwitcher><osd style="thumbnail" /> </windowSwitcher>

  <keyboard>
    <default />
    <keybind key="W-S-t">
      <action name="Execute" command="tts.py" />
    </keybind>
    <keybind key="W-t">
      <action name="Execute" command="tts-jp.py" />
    </keybind>
    <keybind key="W-KP_End">
      <action name="MoveTo" x="0" y="0" />
      <action name="ResizeTo" width="640" height="1080" />
    </keybind>
    <keybind key="W-KP_Down">
      <action name="MoveTo" x="640" y="0" />
      <action name="ResizeTo" width="640" height="1080" />
    </keybind>
    <keybind key="W-KP_Next">
      <action name="MoveTo" x="1280" y="0" />
      <action name="ResizeTo" width="640" height="1080" />
    </keybind>
    <keybind key="W-S-m">
      <action name="Exit" />
    </keybind>
    <keybind key="W-S-equal">
      <action name="Execute" command="zoomer" />
    </keybind>
    <keybind key="W-z">
      <action name="Execute" command="anki-screenshot.sh" />
    </keybind>
    <keybind key="W-x">
      <action name="Execute" command="record-audio.sh" />
    </keybind>
    <keybind key="W-o">
      <action name="Reconfigure" />
    </keybind>
    <keybind key="W-S-s">
      <action name="Execute" command="sh -c 'grim -g &quot;$(slurp)&quot; - | wl-copy'" />
    </keybind>
    <keybind key="Print">
      <action name="Execute" command="sh -c 'grim - | wl-copy'" />
    </keybind>
    <keybind key="XF86AudioPause">
      <action name="Execute" command="playerctl play-pause" />
    </keybind>
    <keybind key="XF86AudioPlay">
      <action name="Execute" command="playerctl play-pause" />
    </keybind>
    <keybind key="W-p">
      <action name="Execute" command="playerctl play-pause" />
    </keybind>
    <keybind key="XF86AudioNext">
      <action name="Execute" command="playerctl next" />
    </keybind>
    <keybind key="XF86AudioPrev">
      <action name="Execute" command="playerctl previous" />
    </keybind>
    <keybind key="W-period">
      <action name="Execute" command="playerctl next" />
    </keybind>
    <keybind key="W-comma">
      <action name="Execute" command="playerctl previous" />
    </keybind>
    <keybind key="W-q">
      <action name="Execute" command="foot" />
    </keybind>
    <keybind key="W-e">
      <action name="Execute" command="pcmanfm-qt" />
    </keybind>
    <keybind key="W-S-c">
      <action name="Close" />
    </keybind>
    <keybind key="W-r">
      <action name="Execute" command="rofi -show drun -show-icons" />
    </keybind>
    <keybind key="W-S-r">
      <action name="Execute" command="rofi -show run" />
    </keybind>
    <keybind key="W-f">
      <action name="ToggleMaximize" direction="both" />
    </keybind>
    <keybind key="W-S-f">
      <action name="ToggleFullscreen" />
    </keybind>
    <keybind key="W-minus">
      <action name="Execute" command="wpctl set-volume @DEFAULT_SINK@ 5%-" />
    </keybind>
    <keybind key="W-equal">
      <action name="Execute" command="wpctl set-volume @DEFAULT_SINK@ 5%+ -l 1" />
    </keybind>
    <keybind key="W-1">
      <action name="GoToDesktop" to="1" />
    </keybind>
    <keybind key="W-2">
      <action name="GoToDesktop" to="2" />
    </keybind>
    <keybind key="W-3">
      <action name="GoToDesktop" to="3" />
    </keybind>
    <keybind key="W-4">
      <action name="GoToDesktop" to="4" />
    </keybind>
    <keybind key="W-5">
      <action name="GoToDesktop" to="5" />
    </keybind>
    <keybind key="W-6">
      <action name="GoToDesktop" to="6" />
    </keybind>
    <keybind key="W-S-1">
      <action name="SendToDesktop" to="1" follow="no" />
    </keybind>
    <keybind key="W-S-2">
      <action name="SendToDesktop" to="2" follow="no" />
    </keybind>
    <keybind key="W-S-3">
      <action name="SendToDesktop" to="3" follow="no" />
    </keybind>
    <keybind key="W-S-4">
      <action name="SendToDesktop" to="4" follow="no" />
    </keybind>
    <keybind key="W-S-5">
      <action name="SendToDesktop" to="5" follow="no" />
    </keybind>
    <keybind key="W-S-6">
      <action name="SendToDesktop" to="6" follow="no" />
    </keybind>
    <keybind key="W-m">
      <action name="ShowMenu" menu="main" />
    </keybind>
  </keyboard>

  <desktops>
    <popupTime>1000</popupTime>
    <initial>1</initial>
    <names>
      <name>1</name>
      <name>2</name>
      <name>3</name>
      <name>4</name>
      <name>5</name>
      <name>6</name>
    </names>
  </desktops>
  <mouse>
    <default />
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="main" />
      </mousebind>
    </context>
  </mouse>

</labwc_config>
