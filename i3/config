set $mod Mod4
set $wallpaper ~/Pictures/wallpaper.png
font pango:Iosevka 12

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -i $wallpaper --nofork
exec --no-startup-id nm-applet
exec --no-startup-id playerctld
exec --no-startup-id xwallpaper --center $wallpaper

bindsym $mod+equal exec --no-startup-id wpctl set-volume @DEFAULT_SINK@ 5%+ -l 1
bindsym $mod+minus exec --no-startup-id wpctl set-volume @DEFAULT_SINK@ 5%-

floating_modifier $mod
tiling_drag       modifier titlebar

bindsym $mod+q            exec alacritty
bindsym $mod+e            exec pcmanfm-qt
bindsym $mod+Shift+equal  exec cboomer
bindsym $mod+y            exec tts.py

bindsym $mod+Shift+s      exec maim -s | xclip -selection clipboard -t image/png
bindsym Print             exec maim    | xclip -selection clipboard -t image/png

bindsym XF86AudioPause    exec playerctl play-pause
bindsym XF86AudioPlay     exec playerctl play-pause
bindsym $mod+p            exec playerctl play-pause

bindsym XF86AudioPrev     exec playerctl previous
bindsym $mod+Shift+comma  exec playerctl previous
bindsym XF86AudioNext     exec playerctl next
bindsym $mod+Shift+period exec playerctl next

bindsym $mod+Shift+r      exec --no-startup-id dmenu_run -fn "Iosevka"
bindsym $mod+r            exec --no-startup-id rofi -show drun -show-icons

bindsym $mod+Shift+c kill

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+w       split toggle

bindsym $mod+f       layout tabbed
bindsym $mod+t       layout toggle split

bindsym $mod+Shift+f fullscreen toggle

bindsym $mod+Shift+v floating toggle
bindsym $mod+v       focus mode_toggle

bindsym $mod+a       focus parent
bindsym $mod+Shift+a focus child

# make default layout=tabbed
workspace_layout tabbed

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+o       reload
bindsym $mod+m       restart
bindsym $mod+Shift+m exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+g mode "default"
}
bindsym $mod+g mode "resize"

bar {
        status_command i3status
}

# enable icons for all window
for_window [all] title_window_icon on

# i want the options window to stop floating
for_window [class="Anki" title="Options"] floating disable

# anki's browse window probably has a different title when i open it, so a normal
# assign command doesn't work
for_window [class="Anki" title="Browse"] move to workspace 2
assign [class="librewolf"] 3
for_window [class="Anki" title="User 1 - Anki"] move to workspace 4
